# ---------------------------------------------------------------------------
# Ads Maker — environment variables
# Copy to .env.local and fill in. Everything runs in a degraded "dev/stub" mode
# when keys are absent, so you can build UI before wiring real providers.
# ---------------------------------------------------------------------------

# ---- App ----
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Guards the background job drain endpoint (/api/jobs/tick). Any random string.
CRON_SECRET=dev-cron-secret
# Optional stable id for a long-running local worker process.
WORKER_ID=local

# ---- Supabase (DB + Auth + RLS) ----
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Media storage (Cloudinary) ----
# STORAGE_DRIVER=local keeps media as passthrough URLs / local disk so phases 0-3
# work with no Cloudinary account. Switch to "cloudinary" once you add the keys.
STORAGE_DRIVER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Providers (app-level keys) ----
# NOTE: image + video generation have NO env keys — they run through the
# Higgsfield MCP, which each user connects in Settings -> Higgsfield.
# LLM / vision (analysis + prompt writing) — Claude
ANTHROPIC_API_KEY=
# Analysis fallback when ANTHROPIC_API_KEY is absent — Gemini (text/vision only)
GEMINI_API_KEY=
# Optional: override the Gemini text model used for ad analysis (default gemini-2.5-flash)
GEMINI_LLM_MODEL=
# Voiceover / TTS — ElevenLabs
ELEVENLABS_API_KEY=
# Optional: default voice id + model for voiceovers
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=
# Ad discovery — Apify (set both the token and the actor id)
APIFY_TOKEN=
APIFY_ADS_ACTOR=

# ---- Cost control ----
# Optional soft/hard monthly spend cap in USD (blank = no cap).
BUDGET_MONTHLY_USD=
